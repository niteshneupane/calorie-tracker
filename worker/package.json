{
  "name": "calorie-tracker-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute calorie_tracker_db --local --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute calorie_tracker_db --remote --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute calorie_tracker_db --local --file=src/db/seed.sql",
    "db:seed:remote": "wrangler d1 execute calorie_tracker_db --remote --file=src/db/seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
